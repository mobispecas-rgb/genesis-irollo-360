# ============================================================
# GENESIS iROLLO 360 — VARIÁVEIS DE AMBIENTE (TEMPLATE)
# MOBIS Peças Automotivas | mobispecas@gmail.com
#
# ATENÇÃO: Este arquivo é um TEMPLATE público.
# As credenciais REAIS devem ser configuradas:
#   - Railway: Settings → Variables
#   - Local: crie um .env.local (nunca commite credenciais reais)
# ============================================================

# ─── SERVIDOR ────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── BLING API v3 — Configure no Railway ─────────────────────
BLING_CLIENT_ID=SEU_CLIENT_ID_AQUI
BLING_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI
BLING_REFRESH_TOKEN=SEU_REFRESH_TOKEN_AQUI
BLING_ACCESS_TOKEN=
BLING_BASE_URL=https://www.bling.com.br/Api/v3

# ─── GEMINI — Google AI Studio ───────────────────────────────
# Obtenha grátis em: https://aistudio.google.com/api-keys
GEMINI_API_KEY=SUA_GEMINI_API_KEY_AQUI
GEMINI_MODEL=gemini-2.0-flash-exp

# ─── WIX Studio ──────────────────────────────────────────────
WIX_API_KEY=SUA_WIX_API_KEY_AQUI
WIX_SITE_ID=SEU_WIX_SITE_ID_AQUI

# ─── MOTOR GENESIS ───────────────────────────────────────────
EMPRESA=MOBIS
NCT_MINIMO=0.90
MARCA_PADRAO=TRIMGO

# ─── FIREBASE (opcional) ─────────────────────────────────────
FIREBASE_PROJECT_ID=genesis-irollo-360
